---
import { Rocket, ShieldCheck, HandCoins } from 'lucide-react'

const features = [
  {
    title: 'Fast',
    description: '80% of background checks results are obtained in less than 24 hours.',
    icon: Rocket,
    color: '#00AEEF'
  },
  {
    title: 'Reliable',
    description: 'Access to more than 800 data bases, from government agencies to educational and professional organizations.',
    icon: ShieldCheck,
    color: '#00334E'
  },
  {
    title: 'Affordable',
    description: 'Complete background check packages starting at $28. No hidden costs.',
    icon: HandCoins,
    color: '#00AEEF'
  }
]
---

<section class="py-20">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid md:grid-cols-3 gap-8">
      {features.map((feature) => (
        <div class="group bg-white p-10 rounded-3xl shadow-sm border border-slate-100 hover:shadow-xl hover:-translate-y-2 transition-all duration-300">
          <div class="mb-8 relative">
            <div 
              class="w-16 h-16 rounded-2xl flex items-center justify-center transition-colors group-hover:scale-110 duration-300"
              style={{ backgroundColor: `${feature.color}10` }}
            >
              <feature.icon 
                size={32} 
                stroke-width={1.5}
                style={{ color: feature.color }}
              />
            </div>
          </div>
          <h3 
            class="text-2xl font-bold mb-4"
            style={{ color: '#00334E' }}
          >
            {feature.title}
          </h3>
          <p class="text-slate-600 leading-relaxed text-lg">
            {feature.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
